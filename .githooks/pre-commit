#!/bin/bash
# Pre-commit hook to propose documentation updates
# Generates docs/generated/* — never touches CLAUDE.md

# DO NOT use set -e - we want to continue on errors

REPO_ROOT="$(git rev-parse --show-toplevel)"
SCRIPT="$REPO_ROOT/scripts/update_docs.py"

# Step 1: Generate/check for changes (suppress errors, never block)
if [ -f "$SCRIPT" ]; then
    OUTPUT=$(python3 "$SCRIPT" --propose --no-build 2>/dev/null) || true

    if echo "$OUTPUT" | grep -q "updates available"; then
        echo ""
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo "Documentation updates available (docs/generated/)"
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo "$OUTPUT"
        echo ""

        # Step 2: Interactive vs non-interactive
        if [ -t 0 ] && [ -t 1 ]; then
            echo "Apply these documentation changes? [y/N]: "
            read -r response
            case "$response" in
                [yY][eE][sS]|[yY])
                    python3 "$SCRIPT" --apply --no-build 2>/dev/null || true
                    git add "$REPO_ROOT/docs/generated/" 2>/dev/null || true
                    echo "Documentation changes applied and staged"
                    ;;
                *)
                    echo "Documentation changes not applied. Run: python3 scripts/update_docs.py --apply"
                    ;;
            esac
        else
            echo "Non-interactive mode: Run python3 scripts/update_docs.py --apply to update."
        fi
    fi
fi

# Always exit 0 - never block commit
exit 0
