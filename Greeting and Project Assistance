  veloMax: number | null;
}) {
  const next = new URLSearchParams();

  if (playerSlug) {
    next.set("player", playerSlug);
  }
  if (pitcherHand !== "all") {
    next.set("pitcherHand", pitcherHand);
  }
  if (season !== (latestSeason ?? "all")) {
    next.set("season", season);
  }
  if (pitchType) {
