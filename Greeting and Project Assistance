        ({
          ...pa,
          initialCount: resolvePlateAppearanceInitialCount(
            pa,
            pitchesByPaId.get(pa.id) ?? [],
          ),
        }) satisfies ChartingPlateAppearance,
    ),
    pitches,
  };
