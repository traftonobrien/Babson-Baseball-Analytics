  const [segments, lineup, plateAppearances, pitches] = await Promise.all([
    db
      .select()
      .from(chartingPitcherSegments)
      .where(eq(chartingPitcherSegments.gameId, gameId))
      .orderBy(asc(chartingPitcherSegments.segmentOrder)),
    db
      .select()
